# Guidorizzi Cálculo I — Environment Variables
# Copie este arquivo para .env e preencha com seus valores

# ============================================================================
# AI PROVIDERS - Obtenha as chaves em:
# - Groq: https://console.groq.com
# - Google GenAI: https://ai.google.dev
# ============================================================================

# Chave de API para Groq (LLM rápido)
VITE_GROQ_API_KEY=gsk_seu_groq_api_key_aqui

# Chave de API para Google GenAI (backup/specializedtasks)
VITE_GOOGLE_API_KEY=AIzaSy_seu_google_api_key_aqui

# ============================================================================
# ENVIRONMENT
# ============================================================================

# Ambiente: development | staging | production
NODE_ENV=development

# Nível de logging: debug | info | warn | error
LOG_LEVEL=info

# ============================================================================
# FRONTEND
# ============================================================================

# URL do backend (deve apontar para Express server)
VITE_API_URL=http://localhost:3001

# Modo offline (se true, não faz requisições ao servidor)
VITE_OFFLINE_MODE=false

# ============================================================================
# BACKEND (Express)
# ============================================================================

# Porta do servidor backend
API_PORT=3001

# Rate limiting - máximo de requisições por minuto por IP
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# CORS - URLs permitidas (separadas por vírgula)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,https://seu-dominio.com

# ============================================================================
# DATABASE (Se usar no futuro)
# ============================================================================

# DATABASE_URL=postgresql://user:password@localhost:5432/guidorizzi

# ============================================================================
# MONITORING (Opcional - Sentry, Datadog, etc)
# ============================================================================

# SENTRY_DSN=https://seu-sentry-dsn@sentry.io/project-id
# DATADOG_API_KEY=seu-datadog-api-key
